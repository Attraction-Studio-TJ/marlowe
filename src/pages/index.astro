---
const rows = 4;
const columns = 5;
const tileWidth = 601;
const tileHeight = 416;
const mosaicRatio = (columns * tileWidth) / (rows * tileHeight);
const jitterPattern = [
	[-0.68, -0.16, 0.1, '36%', '42%'],
	[0.56, 0.12, -0.12, '54%', '45%'],
	[-0.44, 0.08, 0.14, '42%', '55%'],
	[0.74, -0.1, -0.08, '58%', '40%'],
	[-0.52, 0.14, 0.1, '46%', '58%'],
];
const tiles = Array.from({ length: rows * columns }, (_, index) => {
	const row = Math.floor(index / columns) + 1;
	const col = (index % columns) + 1;
	const jitter = jitterPattern[index % jitterPattern.length];
	const centerCol = (columns + 1) / 2;
	const centerRow = (rows + 1) / 2;
	const side = col < centerCol ? -1 : col > centerCol ? 1 : index % 2 === 0 ? -1 : 1;
	const vertical = row < centerRow ? -1 : row > centerRow ? 1 : index % 3 === 0 ? -1 : 1;

	return {
		index,
		row,
		col,
		tilt: `${jitter[0]}deg`,
		shiftX: `${jitter[1]}%`,
		shiftY: `${jitter[2]}%`,
		originX: jitter[3],
		originY: jitter[4],
		menuX: `${side * (34 + Math.abs(col - centerCol) * 11 + (index % 4) * 3)}vw`,
		menuY: `${vertical * (18 + Math.abs(row - centerRow) * 10 + (index % 5) * 2)}vh`,
		menuTilt: `${side * (10 + (index % 7) * 4)}deg`,
		menuDelay: `${(index % 6) * 22}ms`,
	};
});
const tileRows = Array.from({ length: rows }, (_, rowIndex) =>
	tiles.slice(rowIndex * columns, (rowIndex + 1) * columns)
);

const frameFolders = ['1', '2'];
const frames = frameFolders.map((folder) =>
	tiles.map((tile) => `/${folder}/${folder}Marlowe_web_images_Marlowe ${tile.row}.${tile.col}.jpg`)
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="https://use.typekit.net/duj0xcr.css" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Two Image Once Mosaic Tilt Paper Menu</title>
		<meta
			name="description"
			content="A two-frame 4x5 image-set hover prototype where the mosaic scatters to reveal a menu."
		/>
	</head>
	<body>
		<header class="site-header" aria-label="Site header">
			<button
				class="site-link site-link--button"
				type="button"
				aria-controls="menu-panel"
				aria-expanded="false"
				data-menu-toggle
			>
				Menu
			</button>
			<a class="site-logo" href="/" aria-label="Marlowe home">Marlowe</a>
			<a class="site-link site-link--right" href="mailto:book@marlowe.co.nz">Book table</a>
		</header>
		<main class="mosaic-shell" aria-label="Interactive natural-size image mosaic">
			<section
				class="mosaic"
				aria-label="Image fragments arranged with flex rows"
				style={`--rows:${rows}; --columns:${columns}; --mosaic-ratio:${mosaicRatio};`}
			>
				{tileRows.map((row) => (
					<div class="mosaic__row">
						{row.map((tile) => (
							<button
								class="tile"
								type="button"
								data-tile-index={tile.index}
								data-frame="0"
								style={`--tilt:${tile.tilt}; --shift-x:${tile.shiftX}; --shift-y:${tile.shiftY}; --origin-x:${tile.originX}; --origin-y:${tile.originY}; --menu-x:${tile.menuX}; --menu-y:${tile.menuY}; --menu-tilt:${tile.menuTilt}; --menu-delay:${tile.menuDelay};`}
								aria-label={`Reveal image fragment ${tile.index + 1}`}
							>
								<img
									class="tile__image"
									src={frames[0][tile.index]}
									width={tileWidth}
									height={tileHeight}
									alt=""
								/>
								<span class="tile__flash"></span>
							</button>
						))}
					</div>
				))}
			</section>
		</main>
		<aside class="menu-panel" id="menu-panel" aria-label="Restaurant menus" aria-hidden="true">
			<div class="menu-book" aria-live="polite">
				<div class="menu-book__page menu-book__page--left">
					<p class="menu-book__kicker">Marlowe</p>
					<h1>Menus</h1>
					<p class="menu-book__intro">
						Choose a service and the page opens with the current dishes. This keeps the reveal feeling like a
						printed menu rather than a generic overlay.
					</p>
					<div class="menu-book__tabs" role="tablist" aria-label="Choose a menu">
						<button class="menu-tab is-active" type="button" role="tab" id="tab-lunch" aria-controls="menu-lunch" aria-selected="true" data-menu-tab="lunch">
							Lunch
						</button>
						<button class="menu-tab" type="button" role="tab" id="tab-dinner" aria-controls="menu-dinner" aria-selected="false" tabindex="-1" data-menu-tab="dinner">
							Dinner
						</button>
						<button class="menu-tab" type="button" role="tab" id="tab-drinks" aria-controls="menu-drinks" aria-selected="false" tabindex="-1" data-menu-tab="drinks">
							Drinks
						</button>
					</div>
					<p class="menu-book__note">211 High Street, Christchurch<br />Open till late, closed Monday</p>
				</div>

				<div class="menu-book__page menu-book__page--right">
					<section class="menu-sheet is-active" id="menu-lunch" role="tabpanel" aria-labelledby="tab-lunch" data-menu-sheet="lunch">
						<p class="menu-sheet__eyebrow">Midday</p>
						<h2>Lunch</h2>
						<div class="menu-list">
							<p><span>Dry-aged Akaroa salmon, gem lettuce, green goddess</span><b>38</b></p>
							<p><span>Spanner crab pappardelle, garlic, chilli, lemon</span><b>34</b></p>
							<p><span>Steak frites, bordelaise, kombu butter</span><b>40</b></p>
							<p><span>Wagyu beef burger, fries</span><b>29</b></p>
							<p><span>Charred carrots, preserved lemon, pine nut and currant</span><b>28</b></p>
							<p><span>Confit beetroot, brassica, hazelnut</span><b>26</b></p>
						</div>
						<h3>Sides</h3>
						<div class="menu-list menu-list--compact">
							<p><span>Pommes puree, Parmesan, chives</span><b>14</b></p>
							<p><span>Mixed leaves, buttermilk and mint</span><b>14</b></p>
							<p><span>Zucchini, ricotta, citrus</span><b>14</b></p>
						</div>
					</section>

					<section class="menu-sheet" id="menu-dinner" role="tabpanel" aria-labelledby="tab-dinner" hidden data-menu-sheet="dinner">
						<p class="menu-sheet__eyebrow">Evening</p>
						<h2>Dinner</h2>
						<div class="menu-list">
							<p><span>Oysters, mignonette, lemon</span><b>6 ea</b></p>
							<p><span>House focaccia, cultured butter</span><b>12</b></p>
							<p><span>Market fish, brown butter, capers</span><b>42</b></p>
							<p><span>Lamb shoulder, smoked yoghurt, rosemary</span><b>44</b></p>
							<p><span>Charred greens, anchovy cream</span><b>24</b></p>
							<p><span>Chocolate tart, creme fraiche</span><b>20</b></p>
						</div>
					</section>

					<section class="menu-sheet" id="menu-drinks" role="tabpanel" aria-labelledby="tab-drinks" hidden data-menu-sheet="drinks">
						<p class="menu-sheet__eyebrow">Cellar</p>
						<h2>Drinks</h2>
						<div class="menu-list">
							<p><span>Marlowe martini, olive leaf, citrus oil</span><b>24</b></p>
							<p><span>Negroni, blood orange, bitter herbs</span><b>22</b></p>
							<p><span>Seasonal spritz, rhubarb, sparkling wine</span><b>19</b></p>
							<p><span>North Canterbury riesling</span><b>16</b></p>
							<p><span>Central Otago pinot noir</span><b>18</b></p>
							<p><span>House lager</span><b>13</b></p>
						</div>
					</section>
				</div>
			</div>
		</aside>
		<footer class="site-footer" aria-label="Site footer">
			<a class="site-footer__contact" href="mailto:book@marlowe.co.nz">book@marlowe.co.nz</a>
			<p class="site-footer__centre">
				211 High Street Christchurch New Zealand<br />
				Open till late, closed on Monday<br />
				&copy; 2026 Marlowe
			</p>
			<a class="site-footer__contact site-footer__contact--right" href="tel:+64221234567">022 123 4567</a>
		</footer>

		<script define:vars={{ frames }}>
			const tiles = [...document.querySelectorAll('.tile')];
			const menuToggle = document.querySelector('[data-menu-toggle]');
			const menuPanel = document.querySelector('#menu-panel');
			const menuTabs = [...document.querySelectorAll('[data-menu-tab]')];
			const menuSheets = [...document.querySelectorAll('[data-menu-sheet]')];
			const revealFrame = 1;
			let menuCloseTimer;

			function revealTile(tile) {
				if (tile.dataset.revealed === 'true') return;

				const image = tile.querySelector('.tile__image');
				const tileIndex = Number(tile.dataset.tileIndex);
				tile.dataset.frame = String(revealFrame);
				tile.dataset.revealed = 'true';
				image.src = frames[revealFrame][tileIndex];
				tile.dataset.revealing = 'true';
				window.setTimeout(() => delete tile.dataset.revealing, 420);
			}

			tiles.forEach((tile) => {
				tile.addEventListener('pointerenter', () => revealTile(tile));
				tile.addEventListener('focus', () => revealTile(tile));
				tile.addEventListener('click', () => revealTile(tile));
			});

			menuToggle?.addEventListener('click', () => {
				const isOpen = document.body.dataset.menuOpen === 'true';
				window.clearTimeout(menuCloseTimer);

				if (isOpen) {
					document.body.dataset.menuOpen = 'false';
					document.body.dataset.menuClosing = 'true';
					menuCloseTimer = window.setTimeout(() => {
						delete document.body.dataset.menuClosing;
					}, 860);
				} else {
					delete document.body.dataset.menuClosing;
					document.body.dataset.menuOpen = 'true';
				}

				menuToggle.setAttribute('aria-expanded', String(!isOpen));
				menuToggle.textContent = isOpen ? 'Menu' : 'Close';
				menuPanel?.setAttribute('aria-hidden', String(isOpen));
			});

			function setMenu(menuName) {
				menuTabs.forEach((tab) => {
					const isActive = tab.dataset.menuTab === menuName;
					tab.classList.toggle('is-active', isActive);
					tab.setAttribute('aria-selected', String(isActive));
					tab.tabIndex = isActive ? 0 : -1;
				});

				menuSheets.forEach((sheet) => {
					const isActive = sheet.dataset.menuSheet === menuName;
					sheet.classList.toggle('is-active', isActive);
					sheet.hidden = !isActive;
				});
			}

			menuTabs.forEach((tab, index) => {
				tab.addEventListener('click', () => setMenu(tab.dataset.menuTab));
				tab.addEventListener('keydown', (event) => {
					if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;

					event.preventDefault();
					const direction = event.key === 'ArrowLeft' ? -1 : 1;
					const nextIndex =
						event.key === 'Home'
							? 0
							: event.key === 'End'
								? menuTabs.length - 1
								: (index + direction + menuTabs.length) % menuTabs.length;
					menuTabs[nextIndex]?.focus();
					setMenu(menuTabs[nextIndex]?.dataset.menuTab);
				});
			});
		</script>
	</body>
</html>

<style>
	:root {
		--focus: #fff7e7;
		background: #111;
		color: #111;
		font-family: neue-haas-grotesk-display, sans-serif;
		font-style: normal;
		font-weight: 500;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		width: 100%;
		min-width: 320px;
		min-height: 100%;
		margin: 0;
		background: #111;
	}

	button {
		font: inherit;
	}

	body[data-menu-open="true"] {
		overflow: hidden;
	}

	.site-header,
	.site-footer {
		position: fixed;
		z-index: 10;
		left: 0;
		width: 100%;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		padding: clamp(16px, 2.5vw, 28px);
		color: #fff7e7;
		font-size: clamp(0.78rem, 1vw, 0.95rem);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		pointer-events: none;
	}

	.site-header {
		top: 0;
	}

	.site-footer {
		bottom: 0;
		align-items: end;
	}

	.site-link,
	.site-logo,
	.site-footer__contact {
		width: fit-content;
		color: inherit;
		text-decoration: none;
		pointer-events: auto;
	}

	.site-logo {
		justify-self: center;
		font-family: ivyora-display, serif;
		font-size: clamp(1.1rem, 2vw, 1.7rem);
		font-style: normal;
		font-weight: 400;
		letter-spacing: 0.18em;
	}

	.site-link--right,
	.site-footer__contact--right {
		justify-self: end;
	}

	.site-link,
	.site-footer__contact {
		padding: 0.58rem 0.72rem 0.48rem;
		border: 0;
		background: rgba(17, 17, 17, 0.34);
		backdrop-filter: blur(8px);
		cursor: pointer;
	}

	.site-link:hover,
	.site-link:focus-visible,
	.site-footer__contact:hover,
	.site-footer__contact:focus-visible {
		text-decoration: underline;
		text-underline-offset: 0.28em;
	}

	.site-footer__centre {
		max-width: 26rem;
		margin: 0;
		color: rgba(255, 247, 231, 0.82);
		font-size: clamp(0.72rem, 0.95vw, 0.86rem);
		line-height: 1.35;
		letter-spacing: 0.06em;
		text-align: center;
		text-transform: uppercase;
	}

	@media (max-width: 640px) {
		.site-header,
		.site-footer {
			padding: 14px;
		}

		.site-footer {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 0.55rem;
		}

		.site-footer__contact,
		.site-footer__contact--right {
			justify-self: center;
		}
	}

	.mosaic-shell {
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		overflow: hidden;
		background:
			radial-gradient(circle at 18% 16%, rgba(255, 247, 231, 0.12), transparent 30%),
			linear-gradient(135deg, #070707, #1a1510 56%, #0b0a08);
	}

	.mosaic {
		--tile-gap: clamp(1px, 0.16vw, 3px);
		--mosaic-padding: clamp(2px, 0.28vw, 5px);
		position: relative;
		flex: 0 0 auto;
		width: max(100vw, calc(100svh * var(--mosaic-ratio)));
		aspect-ratio: var(--mosaic-ratio);
		display: flex;
		flex-direction: column;
		gap: var(--tile-gap);
		padding: var(--mosaic-padding);
		overflow: hidden;
		isolation: isolate;
		background: #181411;
		box-shadow: 0 30px 90px rgba(0, 0, 0, 0.42);
		z-index: 5;
		transition:
			background 420ms ease,
			box-shadow 420ms ease;
	}

	body[data-menu-open="true"] .mosaic {
		background: transparent;
		box-shadow: none;
	}

	.mosaic::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 3;
		pointer-events: none;
		background:
			linear-gradient(180deg, rgba(0, 0, 0, 0.08), transparent 30%, rgba(0, 0, 0, 0.28)),
			repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.045) 0 1px, transparent 1px 8px);
		opacity: 0.75;
		transition: opacity 300ms ease;
	}

	body[data-menu-open="true"] .mosaic::after {
		opacity: 0;
	}

	.mosaic__row {
		display: flex;
		gap: var(--tile-gap);
		width: 100%;
		line-height: 0;
	}

	.tile {
		position: relative;
		display: block;
		flex: 0 0 calc((100% - ((var(--columns) - 1) * var(--tile-gap))) / var(--columns));
		min-width: 0;
		padding: 0;
		border: 0;
		overflow: hidden;
		cursor: crosshair;
		background: transparent;
		box-shadow:
			0 1px 2px rgba(0, 0, 0, 0.24),
			0 3px 8px rgba(0, 0, 0, 0.2);
		line-height: 0;
		transform: translate3d(0, 0, 0) rotate(0deg);
		transform-origin: var(--origin-x) var(--origin-y);
		transition:
			transform 120ms steps(2, end),
			box-shadow 220ms ease,
			opacity 220ms ease;
	}

	.tile:hover,
	.tile:focus-visible,
	.tile[data-revealed="true"] {
		z-index: 4;
		transform: translate3d(var(--shift-x), var(--shift-y), 0) rotate(var(--tilt));
	}

	body[data-menu-open="true"] .tile {
		z-index: 6;
		opacity: 0.96;
		box-shadow:
			0 5px 14px rgba(0, 0, 0, 0.25),
			0 18px 40px rgba(0, 0, 0, 0.22);
		transform: translate3d(var(--menu-x), var(--menu-y), 0) rotate(var(--menu-tilt)) scale(1.04);
		transition:
			transform 780ms cubic-bezier(0.16, 0.84, 0.22, 1) var(--menu-delay),
			box-shadow 420ms ease var(--menu-delay),
			opacity 420ms ease var(--menu-delay);
	}

	body[data-menu-closing="true"] .tile {
		z-index: 6;
		opacity: 1;
		transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
		transition:
			transform 860ms cubic-bezier(0.16, 0.84, 0.22, 1) var(--menu-delay),
			box-shadow 520ms ease var(--menu-delay),
			opacity 520ms ease var(--menu-delay);
	}

	.tile:focus-visible {
		z-index: 5;
		outline: 3px solid var(--focus);
		outline-offset: -7px;
	}

	.tile__image {
		display: block;
		width: 100%;
		height: auto;
		filter: contrast(1.05) saturate(0.86) grayscale(0.1);
		transform: translate3d(0, 0, 0) scale(1.01);
		transition: filter 120ms steps(2, end);
		user-select: none;
		pointer-events: none;
	}

	.tile:hover .tile__image,
	.tile:focus-visible .tile__image,
	.tile[data-revealed="true"] .tile__image {
		filter: contrast(1.18) saturate(1.04);
	}

	body[data-menu-open="true"] .tile__image {
		filter: contrast(1.08) saturate(0.82) grayscale(0.08);
	}

	.tile__flash {
		position: absolute;
		inset: 0;
		display: block;
		background: #fff7e7;
		opacity: 0;
		mix-blend-mode: screen;
		pointer-events: none;
	}

	.menu-panel {
		--paper: #eee4d6;
		--ink: #9f2926;
		--shadow: rgba(24, 12, 8, 0.38);
		position: fixed;
		inset: 50% auto auto 50%;
		z-index: 4;
		width: min(1180px, calc(100vw - 52px));
		max-height: calc(100svh - 176px);
		color: var(--ink);
		opacity: 0;
		pointer-events: none;
		perspective: 1800px;
		transform: translate(-50%, -44%) scale(0.92) rotate(-1deg);
		transition:
			opacity 340ms ease,
			transform 740ms cubic-bezier(0.16, 0.84, 0.22, 1);
	}

	body[data-menu-open="true"] .menu-panel {
		opacity: 1;
		pointer-events: auto;
		transform: translate(-50%, -50%) scale(1) rotate(-0.35deg);
		transition-delay: 160ms;
	}

	.menu-book {
		position: relative;
		display: grid;
		grid-template-columns: minmax(260px, 0.78fr) minmax(360px, 1.22fr);
		min-height: min(660px, calc(100svh - 176px));
		background:
			linear-gradient(90deg, transparent 0 49.5%, rgba(86, 43, 31, 0.26) 49.9% 50.1%, transparent 50.5%),
			var(--paper);
		box-shadow:
			0 34px 120px rgba(0, 0, 0, 0.48),
			0 8px 20px rgba(0, 0, 0, 0.18);
		transform-style: preserve-3d;
	}

	.menu-book::before,
	.menu-book::after {
		content: "";
		position: absolute;
		pointer-events: none;
	}

	.menu-book::before {
		inset: 0;
		background:
			radial-gradient(circle at 28% 24%, rgba(255, 255, 255, 0.34), transparent 34%),
			repeating-linear-gradient(0deg, rgba(80, 39, 28, 0.038) 0 1px, transparent 1px 9px),
			repeating-linear-gradient(90deg, rgba(80, 39, 28, 0.03) 0 1px, transparent 1px 11px);
		mix-blend-mode: multiply;
		opacity: 0.68;
	}

	.menu-book::after {
		inset: 22px;
		border: 1px solid rgba(159, 41, 38, 0.18);
	}

	.menu-book__page {
		position: relative;
		z-index: 1;
		min-width: 0;
		padding: clamp(28px, 5vw, 70px);
		overflow: hidden;
	}

	.menu-book__page--left {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		border-right: 1px solid rgba(97, 49, 36, 0.16);
		background: linear-gradient(90deg, rgba(255, 247, 231, 0.25), rgba(97, 49, 36, 0.08));
		transform-origin: right center;
	}

	.menu-book__page--right {
		background: linear-gradient(90deg, rgba(97, 49, 36, 0.1), rgba(255, 247, 231, 0.22) 20%, transparent);
		transform-origin: left center;
	}

	body[data-menu-open="true"] .menu-book__page--left {
		animation: openLeftPage 780ms cubic-bezier(0.16, 0.84, 0.22, 1) both 180ms;
	}

	body[data-menu-open="true"] .menu-book__page--right {
		animation: openRightPage 780ms cubic-bezier(0.16, 0.84, 0.22, 1) both 180ms;
	}

	.menu-book__kicker,
	.menu-sheet__eyebrow,
	.menu-book__note {
		margin: 0;
		font-size: clamp(0.72rem, 0.9vw, 0.86rem);
